# Copy to .env and fill in. The app is read-only + an eToro trading CLI; the only
# credentials it needs are eToro API keys. .env is gitignored.

# --- eToro brokerage ---
# Keys from the eToro API Portal (https://api-portal.etoro.com/): Settings >
# Trading > API Key Management. The PUBLIC key (x-api-key) is shared. The USER
# key (x-user-key) is per-environment — generate one for Demo and one for Real
# and store both; ETORO_ENV picks which is used. Give the key Write permission
# to trade, Read for balances/universe. Only the env selected below needs its
# user key filled in.
ETORO_API_KEY=            # public key (x-api-key), shared across demo & real
ETORO_USER_KEY_DEMO=      # demo user key (x-user-key)
ETORO_USER_KEY_REAL=      # real user key (x-user-key)
ETORO_ENV=demo            # demo (virtual money) | real (live money)
ETORO_ORDER_CURRENCY=usd  # currency for amount-based (notional) buys
ETORO_DEFAULT_LEVERAGE=1  # 1 = real stock, no CFD leverage

OPENFIGI_API_KEY=
# --- Networking (optional) ---
# HTTP_TIMEOUT_SECONDS=30

# --- Web UI (optional; read-only, no creds) ---
# MOMENTUM_WEB_HOST=127.0.0.1
# MOMENTUM_WEB_PORT=8800
