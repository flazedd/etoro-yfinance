# ibkr-portfolio-connect configuration
# Copy to `.env` and fill in. `.env` is gitignored — never commit secrets.

# --- IBKR OAuth 1.0a ---
# 1. Generate keys + register at the IBKR Client Portal OAuth setup page
#    (see ../scripts/check_oauth.py for a connectivity test).
# 2. Activation is manual on IBKR's side and propagates on weekend server
#    restarts; expect up to ~1 week between registration and first success.
IBIND_USE_OAUTH=True
IBIND_OAUTH1A_CONSUMER_KEY=
IBIND_OAUTH1A_ACCESS_TOKEN=
IBIND_OAUTH1A_ACCESS_TOKEN_SECRET=
# Absolute paths to the two PRIVATE pem files. When running via
# docker-compose these are overridden to /oauth/*.pem (volume-mounted).
IBIND_OAUTH1A_SIGNATURE_KEY_FP=
IBIND_OAUTH1A_ENCRYPTION_KEY_FP=
# Hex string — extract once via:
#   uv run python scripts/extract_dh_prime.py <dhparam.pem>
IBIND_OAUTH1A_DH_PRIME=

# --- Which account to rebalance ---
# Find via GET /portfolio/accounts once OAuth is active. For paper testing
# use your DUQ-prefixed paper account ID; for live trading, the U-prefixed
# live account ID.
IBKR_ACCOUNT_ID=

# --- bbterminal admin API (source of the target portfolio) ---
# Auth is Supabase email/password -> short-lived JWT, auto-refreshed by
# BBTerminalClient. URL + anon key are public (same values shipped in the web
# app's JS bundle); the PASSWORD is the only real secret — never commit it.
# Your account needs the `admin` role to read /api/admin/* (check via whoami).
BBTERMINAL_BASE_URL=https://bbterminal-production.up.railway.app
SUPABASE_URL=https://yilhjhmfwcnzryzeuwci.supabase.co
SUPABASE_ANON_KEY=sb_publishable_PflBa51pUa85x9vx3wzr8w__jsUjkpP
BBTERMINAL_EMAIL=
BBTERMINAL_PASSWORD=

# --- Target portfolio source (legacy: plain JSON over HTTP) ---
# Only used by the older target.py path; bbterminal above is the live source.
TARGET_PORTFOLIO_URL=
# Optional bearer token if the target URL is authenticated.
TARGET_PORTFOLIO_AUTH_TOKEN=

# --- bbterminal rebalance (scripts/rebalance.py) ---
# Currency the strategy is denominated in. Sizing uses entry_price_eur and the
# account NAV must be in this currency (no auto-FX in v1).
SIZING_CURRENCY=EUR
# Refuse to trade unless bbterminal health.is_healthy_strict is true.
REQUIRE_STRATEGY_HEALTHY=true
# Reviewed conid map the rebalancer trades off (run scripts/sync_conid_map.py).
CONID_MAP_PATH=conid_map.json
# Refuse if the strategy snapshot (as_of_date) is older than this many days.
MAX_STRATEGY_AGE_DAYS=14

# --- Safety / behavior ---
# When true, the rebalancer prints the planned trade list and exits without
# placing any orders. Recommended for the first few real runs.
DRY_RUN=false
# Refuse to place orders outside Regular Trading Hours. NOTE: this checks US
# (NY) market hours only — for the global strategy (Tokyo/HK/EU listings) set
# this false and let IBKR queue/reject per market until per-exchange RTH lands.
TRADING_HOURS_ONLY=true

# --- Pre-trade safety thresholds ---
# Each fires BEFORE any order is placed. Set to blank to disable individually.
# Defaults are conservative; tighten as you build trust in the pipeline.
# MIN_NAV_DOLLARS=1000               # refuse if account NAV below this
# MAX_TRADE_PCT_OF_NAV=50            # refuse any single trade > X% of NAV
# MAX_TOTAL_CHURN_PCT_OF_NAV=100     # refuse if total volume > X% of NAV
# MAX_REFERENCE_AGE_HOURS=24         # refuse if any reference_price is older

# --- Run records + dashboard (optional) ---
# If set, each run is saved to {REPORT_DIR}/{timestamp}.json — the audit trail
# the dashboard reads (gates, NAV, current-vs-target, fills). The docker-compose
# stack points these at the shared volume automatically; set them here for a
# bare-metal run.
# REPORT_DIR=/home/pi/rebalance-history
# LOG_DIR=/home/pi/rebalance-logs           # rotating rebalance.log lives here
# Read-only dashboard server (a SEPARATE process; never trades, holds no creds).
# Bind to the LAN only — do NOT expose to the internet.
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=8080

# --- Notifications (optional) ---
# ntfy.sh push topic — pick a long random string (anyone with the topic
# can read your pushes). Leave blank to disable push and log-only.
NTFY_TOPIC=
# NTFY_SERVER=https://ntfy.sh   # override to a self-hosted server if needed
