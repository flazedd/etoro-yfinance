# ibkr-portfolio-connect configuration
# Copy to `.env` and fill in. `.env` is gitignored — never commit secrets.

# --- IBKR OAuth 1.0a ---
# 1. Generate keys + register at the IBKR Client Portal OAuth setup page
#    (see ../scripts/check_oauth.py for a connectivity test).
# 2. Activation is manual on IBKR's side and propagates on weekend server
#    restarts; expect up to ~1 week between registration and first success.
IBIND_USE_OAUTH=True
IBIND_OAUTH1A_CONSUMER_KEY=
IBIND_OAUTH1A_ACCESS_TOKEN=
IBIND_OAUTH1A_ACCESS_TOKEN_SECRET=
# Absolute paths to the two PRIVATE pem files. When running via
# docker-compose these are overridden to /oauth/*.pem (volume-mounted).
IBIND_OAUTH1A_SIGNATURE_KEY_FP=
IBIND_OAUTH1A_ENCRYPTION_KEY_FP=
# Hex string — extract once via:
#   uv run python scripts/extract_dh_prime.py <dhparam.pem>
IBIND_OAUTH1A_DH_PRIME=

# --- Which account to rebalance ---
# Find via GET /portfolio/accounts once OAuth is active. For paper testing
# use your DUQ-prefixed paper account ID; for live trading, the U-prefixed
# live account ID.
IBKR_ACCOUNT_ID=

# --- Target portfolio source ---
# The rebalancer GETs this URL and expects the schema documented in
# examples/target-portfolio.example.json.
TARGET_PORTFOLIO_URL=
# Optional bearer token if the target URL is authenticated.
TARGET_PORTFOLIO_AUTH_TOKEN=

# --- Safety / behavior ---
# When true, the rebalancer prints the planned trade list and exits without
# placing any orders. Recommended for the first few real runs.
DRY_RUN=false
# Refuse to place orders outside Regular Trading Hours.
TRADING_HOURS_ONLY=true

# --- Pre-trade safety thresholds ---
# Each fires BEFORE any order is placed. Set to blank to disable individually.
# Defaults are conservative; tighten as you build trust in the pipeline.
# MIN_NAV_DOLLARS=1000               # refuse if account NAV below this
# MAX_TRADE_PCT_OF_NAV=50            # refuse any single trade > X% of NAV
# MAX_TOTAL_CHURN_PCT_OF_NAV=100     # refuse if total volume > X% of NAV
# MAX_REFERENCE_AGE_HOURS=24         # refuse if any reference_price is older

# --- Report persistence (optional) ---
# If set, each RebalanceReport is saved to {REPORT_DIR}/{timestamp}.json.
# REPORT_DIR=/home/pi/rebalance-history

# --- Notifications (optional) ---
# ntfy.sh push topic — pick a long random string (anyone with the topic
# can read your pushes). Leave blank to disable push and log-only.
NTFY_TOPIC=
# NTFY_SERVER=https://ntfy.sh   # override to a self-hosted server if needed
