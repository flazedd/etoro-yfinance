# ibkr-portfolio-connect configuration
# Copy to `.env` and fill in. `.env` is gitignored — never commit secrets.

# --- IBKR credentials (consumed by IBeam for headless auto-login) ---
IBKR_USERNAME=
IBKR_PASSWORD=
# Base32 TOTP seed for IBKR 2FA. Required for unattended cron runs.
# Get this when enrolling IBKR's IB Key / soft 2FA.
IBKR_TOTP_SECRET=

# --- Which account to rebalance ---
# Find via GET /portfolio/accounts once the gateway is up; copy the accountId here.
IBKR_ACCOUNT_ID=

# --- Local Client Portal Gateway (IBeam exposes it here by default) ---
IBKR_GATEWAY_URL=https://localhost:5000
# IBeam uses a self-signed cert; set to "false" to skip TLS verify when the
# rebalancer talks to the local gateway only.
IBKR_GATEWAY_VERIFY_SSL=false

# --- Target portfolio source ---
# The rebalancer GETs this URL and expects the schema documented in
# examples/target-portfolio.example.json.
TARGET_PORTFOLIO_URL=
# Optional bearer token if the target URL is authenticated.
TARGET_PORTFOLIO_AUTH_TOKEN=

# --- Safety / behavior ---
# When true, the rebalancer prints the planned trade list and exits without
# placing any orders. Recommended for the first few real runs.
DRY_RUN=false
# Refuse to place orders outside Regular Trading Hours.
TRADING_HOURS_ONLY=true

# --- Notifications (optional, configured in a later milestone) ---
NOTIFY_WEBHOOK_URL=
